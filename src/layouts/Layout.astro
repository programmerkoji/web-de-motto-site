---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
}

const {
  title = '町のIT相談所 | 難しいITを、相談しやすく、ちょうどよく整える',
  description = '中小企業や個人事業主向けに、Webサイト・業務改善・IT活用を相談しやすく支援する町のIT相談所です。',
  pathname = '/',
} = Astro.props;

const siteName = '町のIT相談所';
const siteBase = import.meta.env.PUBLIC_SITE_URL || Astro.site?.toString() || 'https://example.com';
const siteUrl = new URL(siteBase);
const canonicalUrl = new URL(pathname, siteUrl).toString();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="format-detection" content="telephone=no, email=no, address=no" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonicalUrl} />
  </head>
  <body>
    <div class="site-shell">
      <Header />
      <main id="main-content">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
