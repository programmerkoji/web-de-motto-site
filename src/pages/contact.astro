---
import Layout from '../layouts/Layout.astro';
import { contactExamples, siteInfo } from '../data/site';

const contactFormAction = import.meta.env.PUBLIC_CONTACT_FORM_ACTION || '#';
const contactConfirmPath = '/contact/confirm/';
const contactStorageKey = 'contact-form-draft';
---

<Layout
  title="お問い合わせ | ウェブでもっと"
  description="Excel整理、IT化の相談、Webシステム制作、ホームページ見直しなどのご相談を受け付けています。"
  pathname="/contact"
>
  <section class="pt-32 pb-20">
    <div class="container-shell">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-3xl font-bold text-brand-text md:text-4xl">お問い合わせ</h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-600">
          小さなご相談から大丈夫です。<br>まだ内容がまとまっていなくても、今困っていることをわかる範囲でお送りください。
        </p>
      </div>

      <div class="mx-auto mt-12 grid max-w-5xl gap-8 lg:grid-cols-[0.8fr_1.2fr]">
        <div class="surface-panel p-8">
          <p class="text-sm font-bold text-teal-700">相談例</p>
          <ul class="mt-5 grid gap-3">
            {contactExamples.map((example) => <li class="rounded-lg bg-slate-50 px-4 py-3">{example}</li>)}
          </ul>

          <!-- <div class="mt-6 rounded-xl bg-teal-50 px-5 py-4 text-sm leading-7 text-slate-600">
            メールでのご連絡先:
            <a class="font-bold text-teal-700" href={`mailto:${siteInfo.contactEmail}`}>{siteInfo.contactEmail}</a>
          </div> -->
        </div>

        <form class="surface-panel p-8" action={contactFormAction} method="post" data-contact-form>
          <div class="mb-4">
            <label class="mb-2 block text-sm font-bold text-brand-text" for="name">お名前</label>
            <input
              id="name"
              name="name"
              type="text"
              autocomplete="name"
              required
              class="w-full rounded-lg border border-slate-200 bg-slate-50 p-3"
            />
          </div>
          <div class="mb-4">
            <label class="mb-2 block text-sm font-bold text-brand-text" for="email">メールアドレス</label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              required
              class="w-full rounded-lg border border-slate-200 bg-slate-50 p-3"
            />
          </div>
          <div class="mb-6">
            <label class="mb-2 block text-sm font-bold text-brand-text" for="message">ご相談内容</label>
            <textarea
              id="message"
              name="message"
              rows="6"
              required
              class="w-full rounded-lg border border-slate-200 bg-slate-50 p-3"
              placeholder="例：Excel作業を楽にしたい、ホームページを見直したい、など"
            ></textarea>
          </div>
          <p class="mb-6 text-sm text-slate-500">
            入力後に確認画面へ進みます。内容をご確認いただいてから送信されます。
          </p>
          <button type="submit" class="w-full rounded-xl bg-brand-accent px-6 py-4 font-bold text-white transition hover:bg-brand-accent-dark">
            確認画面へ進む
          </button>
          <noscript>
            <p class="mt-4 text-sm text-slate-500">
              JavaScript が無効な場合は確認画面を省略して送信されます。
            </p>
          </noscript>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script
  is:inline
  define:vars={{ contactConfirmPath, contactStorageKey }}
>
  const form = document.querySelector('[data-contact-form]');

  if (form instanceof HTMLFormElement) {
    const saved = sessionStorage.getItem(contactStorageKey);

    if (saved) {
      try {
        const values = JSON.parse(saved);
        for (const [name, value] of Object.entries(values)) {
          const field = form.elements.namedItem(name);
          if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement) {
            field.value = String(value);
          }
        }
      } catch {
        sessionStorage.removeItem(contactStorageKey);
      }
    }

    form.addEventListener('submit', (event) => {
      event.preventDefault();

      if (!form.reportValidity()) {
        return;
      }

      const formData = new FormData(form);
      const payload = Object.fromEntries(
        Array.from(formData.entries(), ([key, value]) => [key, String(value).trim()]),
      );

      sessionStorage.setItem(contactStorageKey, JSON.stringify(payload));
      window.location.href = contactConfirmPath;
    });
  }
</script>
