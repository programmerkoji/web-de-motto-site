---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import ProblemsSection from '../components/sections/ProblemsSection.astro';
import ServicesSection from '../components/sections/ServicesSection.astro';
import FeaturesSection from '../components/sections/FeaturesSection.astro';
import PricingSection from '../components/sections/PricingSection.astro';
import ProfileSection from '../components/sections/ProfileSection.astro';
import FlowSection from '../components/sections/FlowSection.astro';
import CtaSection from '../components/sections/CtaSection.astro';
---

<Layout
  title="ウェブでもっと | 町のIT相談所"
  description="中小企業・個人事業のための町のIT相談所。Excelの自動化からホームページ制作まで、小さなITの困りごとを相談しやすく支援します。"
  pathname="/"
>
  <HeroSection />
  <ProblemsSection />
  <ServicesSection />
  <FeaturesSection />
  <PricingSection />
  <ProfileSection />
  <FlowSection />
  <CtaSection />
</Layout>
