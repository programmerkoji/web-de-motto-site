---
import SectionHeading from '../ui/SectionHeading.astro';
import { featureItems } from '../../data/site';
---

<section class="section-pad bg-white">
  <div class="container-shell">
    <SectionHeading
      title="相談しやすさを大切にしています"
      description="士業サイトほど堅くなく、スタートアップほど派手すぎない。地元の相談窓口として安心してもらえる空気感を目指しています。"
    />

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        featureItems.map((item) => (
          <article class="surface-panel p-8">
            <h3 class="text-lg font-bold text-brand-text">{item.title}</h3>
            <p class="mt-4 text-sm leading-7 text-slate-500">{item.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
