---
import SectionHeading from '../ui/SectionHeading.astro';
import { services } from '../../data/site';
---

<section id="services" class="section-pad">
  <div class="container-shell text-center">
    <SectionHeading>
      ITまわりの困りごとを、<br>まとめて相談できます
      <span slot="description">
        Excel、ホームページ、ITツール選び、AI活用、業務効率化など。<br />
        「どこに相談すればいいかわからない」小さな困りごとを、月額で継続サポートします。
      </span>
    </SectionHeading>

    <div class="mt-16 grid gap-8 md:grid-cols-2">
      {
        services.map((service) => (
          <article class="surface-panel p-8 text-left">
            <div class="text-3xl">{service.icon}</div>
            <h3 class="mt-4 text-lg font-bold text-brand-text">{service.title}</h3>
            <p class="mt-2 text-sm leading-7 text-slate-500 whitespace-pre-line">{service.description}</p>
            <ul class="mt-4 grid gap-2 text-sm text-slate-600">
              {service.examples.map((example) => <li>{example}</li>)}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
