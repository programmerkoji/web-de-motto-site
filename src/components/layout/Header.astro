---
import PrimaryLink from '../ui/PrimaryLink.astro';

const currentPath = Astro.url.pathname;
const basePath = currentPath === '/' ? '' : '/';

const navItems = [
  { href: `${basePath}#services`, label: 'サービス' },
  { href: `${basePath}#pricing`, label: '料金' },
  { href: `${basePath}#profile`, label: '代表紹介' },
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-slate-100 bg-white/80 backdrop-blur-md">
  <div class="container-shell flex h-16 items-center justify-between">
    <a href="/" class="flex items-center w-40 md:w-48">
      <img src="/images/logo.png" alt="ウェブでもっと" class="w-full" />
    </a>

    <div class="flex items-center gap-4">
      <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-brand-text">
        {
          navItems.map((item) => (
            <a href={item.href} class="transition hover:text-teal-600">
              {item.label}
            </a>
          ))
        }
      </nav>
      <PrimaryLink href="/contact">無料相談</PrimaryLink>
    </div>
  </div>
</header>
