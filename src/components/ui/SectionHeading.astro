---
interface Props {
  align?: 'left' | 'center';
}

const { align = 'center' } = Astro.props;
const isCenter = align === 'center';
const hasDescription = Astro.slots.has('description');
---

<div class:list={['mx-auto', isCenter ? 'max-w-3xl text-center' : 'max-w-2xl']}>
  <h2 class="text-2xl font-bold text-brand-text md:text-3xl">
    <slot />
  </h2>
  {
    hasDescription && (
      <div class="mt-4 text-base leading-8 text-brand-muted">
        <slot name="description" />
      </div>
    )
  }
</div>
